# ══════════════════════════════════════════════════════════
# SVIES — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ── Supabase Configuration (REQUIRED) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# ── Firebase Configuration ──
FIREBASE_SERVICE_ACCOUNT_PATH=data/firebase-service-account.json

# ── Firebase Frontend (Vite) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── CORS Configuration ──
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:3000

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_UPLOAD=10/minute

# ── Twilio SMS Configuration (optional) ──
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+1xxxxxxxxxx

# ── Gmail SMTP Configuration (optional) ──
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here

# ── Alert Recipients ──
POLICE_EMAIL=police_station@example.com
POLICE_PHONE=+919999999999
RTO_EMAIL=rto_office@example.com

# ── Paths (relative to project root) ──
GEOZONES_PATH=data/geozones/zones.json
SNAPSHOT_DIR=snapshots

# ── Detection Thresholds ──
CONFIDENCE_THRESHOLD=0.40
OCR_MIN_CONFIDENCE=0.3

# ── Roboflow Configuration ──
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# ── Speed Estimator ──
PIXELS_PER_METER=8.0
DEFAULT_SPEED_LIMIT_KMH=40.0

# ── Model Versioning ──
MODEL_VERSION=v1.0

# ── Groq Configuration ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
